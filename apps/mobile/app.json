{
  "expo": {
    "name": "Zepto",
    "slug": "zepto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3b0764"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zepto.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3b0764"
      },
      "package": "com.vpbhaskar.zepto"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3b0764"
        }
      ],
      "expo-font"
    ],
    "scheme": "zepto",
    "extra": {
      "apiUrl": "http://localhost:3001/api/v1",
      "eas": {
        "projectId": "44170767-8560-4f9b-9498-6955de94b9f5"
      }
    }
  }
}
